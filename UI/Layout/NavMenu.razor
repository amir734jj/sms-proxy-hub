@inject AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

<HxNavbar CssClass="bg-dark mb-3" ColorMode="ColorMode.Dark" Expand="NavbarExpand.MediumUp">
    <HxNavbarBrand Href="/">SMS Proxy Hub</HxNavbarBrand>
    <HxNavbarToggler CollapseTarget="#mainNav" />
    <HxNavbarCollapse Id="mainNav">
        <HxNav CssClass="me-auto mb-2 mb-md-0">
            @if (Auth.IsAuthenticated)
            {
                <HxNavLink Href="" Match="NavLinkMatch.All">Dashboard</HxNavLink>
                <HxNavLink Href="connections">Connections</HxNavLink>
                <HxNavLink Href="send-sms">Send SMS</HxNavLink>
                <HxNavLink Href="messages">Messages</HxNavLink>
                <HxNavLink Href="webhooks">Webhooks</HxNavLink>
                <HxNavLink Href="api-tokens">API Tokens</HxNavLink>
            }
            @if (Auth.IsAdmin)
            {
                <HxNavLink Href="admin/users">Users</HxNavLink>
            }
        </HxNav>
        @if (Auth.IsAuthenticated)
        {
            <span class="navbar-text text-white-50 me-2">Hi, @Auth.DisplayLabel</span>
            <HxButton Text="Profile" Color="ThemeColor.Secondary" Size="ButtonSize.Small" CssClass="me-1" OnClick="@(() => Nav.NavigateTo("/profile"))" />
            <HxButton Text="Logout" Color="ThemeColor.Danger" Size="ButtonSize.Small" OnClick="Logout" />
        }
    </HxNavbarCollapse>
</HxNavbar>

@code {
    protected override void OnInitialized() => Auth.AuthStateChanged += StateHasChanged;
    public void Dispose() => Auth.AuthStateChanged -= StateHasChanged;

    async Task Logout()
    {
        await Auth.ClearTokenAsync();
        Nav.NavigateTo("/login");
    }
}
