@page "/connections"
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject IHxMessageBoxService MessageBox

<PageTitle>Connections - SMS Proxy Hub</PageTitle>

@if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

<div class="d-flex align-items-center mb-4">
    <h4 class="mb-0">SMS Connections</h4>
    <div class="ms-auto">
        <HxButton Text="Refresh" Color="ThemeColor.Secondary" Size="ButtonSize.Small" OnClick="LoadAsync" />
    </div>
</div>

@if (_error is not null) { <HxAlert Color="ThemeColor.Danger" CssClass="mb-3">@_error</HxAlert> }
@if (_success is not null) { <HxAlert Color="ThemeColor.Success" CssClass="mb-3">@_success</HxAlert> }

<HxCard CssClass="mb-4">
    <HeaderTemplate><strong>Add Connection</strong></HeaderTemplate>
    <BodyTemplate>
        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" @bind="_newName" placeholder="My SmsGate" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Provider</label>
                <select class="form-select" @bind="_newProvider">
                    <option value="@SmsProviderType.SmsGate">SmsGate</option>
                    <option value="@SmsProviderType.Twilio">Twilio</option>
                </select>
            </div>
            @if (_newProvider == SmsProviderType.SmsGate)
            {
                <SmsGateConfigForm @ref="_smsGateForm" OnError="e => { _error = e; StateHasChanged(); }" />
            }
            else
            {
                <TwilioConfigForm @ref="_twilioForm" />
            }
            <div class="col-md-1 d-flex align-items-end">
                <HxButton Text="Create" Color="ThemeColor.Primary" OnClick="CreateAsync" CssClass="w-100" />
            </div>
        </div>
    </BodyTemplate>
</HxCard>

@if (_connections.Count == 0 && !_loading)
{
    <p class="text-muted">No connections. Create one above.</p>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var c in _connections)
        {
            <HxCard>
                <BodyTemplate>
                    <div class="d-flex align-items-center">
                        <div class="d-flex flex-column me-2">
                            <button class="btn btn-sm btn-outline-secondary py-0 mb-1" @onclick="@(() => MoveAsync(c, -1))"
                                    disabled="@(_connections.IndexOf(c) == 0)" title="Move up (higher priority)">&#9650;</button>
                            <button class="btn btn-sm btn-outline-secondary py-0" @onclick="@(() => MoveAsync(c, 1))"
                                    disabled="@(_connections.IndexOf(c) == _connections.Count - 1)" title="Move down (lower priority)">&#9660;</button>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@c.Name</div>
                            <div class="d-flex gap-2 mt-1">
                                <span class="badge bg-info">@c.ProviderType</span>
                                <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span>
                                <span class="badge bg-dark" title="Failover priority (lower = tried first)">Priority: @c.Priority</span>
                                <small class="text-muted" title="Auto-registered with the provider on connection create">Webhook: <code>/api/provider-webhook/@c.Id</code></small>
                            </div>
                        </div>
                        <HxButton Text="Delete" Color="ThemeColor.Danger" Size="ButtonSize.Small"
                                  OnClick="@(() => DeleteAsync(c))" />
                    </div>
                </BodyTemplate>
            </HxCard>
        }
    </div>
}

@code {
    List<SmsConnectionDto> _connections = [];
    bool _loading;
    string? _error, _success;
    string _newName = "";
    SmsProviderType _newProvider = SmsProviderType.SmsGate;
    SmsGateConfigForm? _smsGateForm;
    TwilioConfigForm? _twilioForm;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _loading = true; _error = null;
        try { _connections = await Api.GetConnectionsAsync(); }
        catch (Exception ex) { _error = $"Failed to load: {ex.Message}"; }
        finally { _loading = false; }
    }

    async Task CreateAsync()
    {
        _error = null; _success = null;
        if (string.IsNullOrWhiteSpace(_newName)) { _error = "Name is required."; return; }

        SmsConnectionConfig config = _newProvider switch
        {
            SmsProviderType.SmsGate => _smsGateForm!.GetConfig(),
            SmsProviderType.Twilio => _twilioForm!.GetConfig(),
            _ => throw new InvalidOperationException()
        };

        try
        {
            await Api.CreateConnectionAsync(new CreateConnectionRequest(_newName.Trim(), config));
            _newName = "";
            _smsGateForm?.Reset();
            _twilioForm?.Reset();
            _success = "Connection created.";
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed: {ex.Message}"; }
    }

    async Task DeleteAsync(SmsConnectionDto c)
    {
        if (!await MessageBox.ConfirmAsync("Delete Connection", $"Delete '{c.Name}'?")) return;
        try { await Api.DeleteConnectionAsync(c.Id); _success = "Deleted."; await LoadAsync(); }
        catch (Exception ex) { _error = $"Failed: {ex.Message}"; }
    }

    async Task MoveAsync(SmsConnectionDto c, int direction)
    {
        var idx = _connections.IndexOf(c);
        var newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= _connections.Count) return;

        (_connections[idx], _connections[newIdx]) = (_connections[newIdx], _connections[idx]);

        try
        {
            await Api.ReorderConnectionsAsync(_connections.Select(x => x.Id).ToList());
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Reorder failed: {ex.Message}"; }
    }
}
