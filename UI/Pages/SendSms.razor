@page "/send-sms"
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Send SMS - SMS Proxy Hub</PageTitle>

@if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

<h4 class="mb-4">Send SMS</h4>

@if (_error is not null) { <HxAlert Color="ThemeColor.Danger" CssClass="mb-3">@_error</HxAlert> }
@if (_success is not null) { <HxAlert Color="ThemeColor.Success" CssClass="mb-3">@_success</HxAlert> }

<HxCard>
    <BodyTemplate>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Connection</label>
                <select class="form-select" @bind="_connectionId">
                    <option value="">Auto (try all by priority)</option>
                    @foreach (var c in _connections)
                    {
                        <option value="@c.Id">@c.Name (@c.ProviderType)</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Phone Number</label>
                <input type="text" class="form-control" @bind="_phone" placeholder="+1234567890" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Payload (optional JSON)</label>
                <textarea class="form-control font-monospace" @bind="_payload" rows="3" placeholder='{"clinicId":"..."}'></textarea>
            </div>
            <div class="col-12">
                <label class="form-label">Message <small class="text-muted">(@_message.Length / 1600)</small></label>
                <textarea class="form-control" @bind="_message" rows="3" maxlength="1600" placeholder="Enter your message"></textarea>
            </div>
            <div class="col-12">
                <HxButton Text="Send" Color="ThemeColor.Primary" OnClick="SendAsync" Enabled="@(!_busy)" />
            </div>
        </div>
    </BodyTemplate>
</HxCard>

@code {
    List<SmsConnectionDto> _connections = [];
    string _connectionId = "", _phone = "", _message = "", _payload = "";
    string? _error, _success;
    bool _busy;

    protected override async Task OnInitializedAsync()
    {
        try { _connections = await Api.GetConnectionsAsync(); }
        catch (Exception ex) { _error = $"Failed to load connections: {ex.Message}"; }
    }

    async Task SendAsync()
    {
        _error = null; _success = null;
        Guid? connId = Guid.TryParse(_connectionId, out var parsed) ? parsed : null;
        if (string.IsNullOrWhiteSpace(_phone) || string.IsNullOrWhiteSpace(_message)) { _error = "Phone and message are required."; return; }
        if (_message.Length > 1600) { _error = "Message too long (max 1600 characters)."; return; }

        _busy = true;
        try
        {
            var result = await Api.SendSmsAsync(new SendSmsRequest
            {
                ConnectionId = connId,
                PhoneNumbers = [_phone],
                Message = _message,
                Payload = string.IsNullOrWhiteSpace(_payload) ? null : _payload
            });
            var first = result.Results.FirstOrDefault();
            _success = $"SMS {first?.Status ?? "unknown"}. Message ID: {first?.MessageId ?? "N/A"}";
            _phone = ""; _message = ""; _payload = "";
        }
        catch (Exception ex) { _error = $"Failed: {ex.Message}"; }
        finally { _busy = false; }
    }
}
