@page "/webhooks"
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject IHxMessageBoxService MessageBox

<PageTitle>Webhooks - SMS Proxy Hub</PageTitle>

@if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

<div class="d-flex align-items-center mb-4">
    <h4 class="mb-0">Webhook Subscriptions</h4>
    <div class="ms-auto">
        <HxButton Text="Refresh" Color="ThemeColor.Secondary" Size="ButtonSize.Small" OnClick="LoadAsync" />
    </div>
</div>

@if (_error is not null) { <HxAlert Color="ThemeColor.Danger" CssClass="mb-3">@_error</HxAlert> }
@if (_success is not null) { <HxAlert Color="ThemeColor.Success" CssClass="mb-3">@_success</HxAlert> }

<HxCard CssClass="mb-4">
    <HeaderTemplate><strong>Add Webhook</strong></HeaderTemplate>
    <BodyTemplate>
        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Connection</label>
                <select class="form-select" @bind="_newConnectionId">
                    <option value="">Select</option>
                    @foreach (var c in _connections)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-8">
                <label class="form-label">Webhook URL</label>
                <input type="text" class="form-control" @bind="_newUrl" placeholder="https://your-app.com/webhook" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <HxButton Text="Add" Color="ThemeColor.Primary" OnClick="CreateAsync" CssClass="w-100" />
            </div>
        </div>
        <small class="text-muted mt-1 d-block">When a reply is received, the original payload you sent will be echoed back to this URL.</small>
    </BodyTemplate>
</HxCard>

@if (_webhooks.Count == 0 && !_loading)
{
    <p class="text-muted">No webhook subscriptions.</p>
}
else
{
    <div class="d-flex flex-column gap-2">
        @foreach (var w in _webhooks)
        {
            <HxCard>
                <BodyTemplate>
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <code>@w.Url</code>
                            <small class="text-muted ms-2">Connection: @w.ConnectionId</small>
                        </div>
                        <HxButton Text="Delete" Color="ThemeColor.Danger" Size="ButtonSize.Small"
                                  OnClick="@(() => DeleteAsync(w))" />
                    </div>
                </BodyTemplate>
            </HxCard>
        }
    </div>
}

<div class="d-flex align-items-center mt-4 mb-3">
    <h5 class="mb-0">Delivery History</h5>
    <div class="ms-auto">
        <HxButton Text="Refresh" Color="ThemeColor.Secondary" Size="ButtonSize.Small" OnClick="LoadAsync" />
    </div>
</div>

@if (_deliveries.Count == 0)
{
    <p class="text-muted">No webhook deliveries yet.</p>
}
else
{
<div class="table-responsive">
    <table class="table table-sm">
        <thead>
            <tr><th>Event</th><th>URL</th><th>Status</th><th>Error</th><th>Time</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var d in _deliveries)
            {
                <tr>
                    <td><span class="badge bg-info">@d.Event</span></td>
                    <td><code class="text-truncate" style="max-width:250px; display:block" title="@d.Url">@d.Url</code></td>
                    <td>
                        @if (d.Success)
                        {
                            <span class="badge bg-success">@d.HttpStatus</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@(d.HttpStatus?.ToString() ?? "Failed")</span>
                        }
                    </td>
                    <td><small class="text-muted">@(d.Error ?? "-")</small></td>
                    <td><small>@d.CreatedAt.LocalDateTime.ToString("MMM dd HH:mm:ss")</small></td>
                    <td><HxButton Text="Replay" Color="ThemeColor.Warning" Size="ButtonSize.Small" OnClick="@(() => ReplayAsync(d.Id))" /></td>
                </tr>
            }
        </tbody>
    </table>
</div>
}

@code {
    List<WebhookSubscriptionDto> _webhooks = [];
    List<WebhookDeliveryDto> _deliveries = [];
    List<SmsConnectionDto> _connections = [];
    bool _loading;
    string? _error, _success;
    string _newConnectionId = "", _newUrl = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        try { _connections = await Api.GetConnectionsAsync(); } catch { }
    }

    async Task LoadAsync()
    {
        _loading = true; _error = null;
        try
        {
            _webhooks = await Api.GetWebhooksAsync();
            _deliveries = await Api.GetWebhookDeliveriesAsync();
        }
        catch (Exception ex) { _error = $"Failed: {ex.Message}"; }
        finally { _loading = false; }
    }

    async Task CreateAsync()
    {
        _error = null; _success = null;
        if (!Guid.TryParse(_newConnectionId, out var connId)) { _error = "Select a connection."; return; }
        if (string.IsNullOrWhiteSpace(_newUrl)) { _error = "URL is required."; return; }

        try
        {
            await Api.CreateWebhookAsync(new CreateWebhookRequest(connId, _newUrl.Trim()));
            _newUrl = ""; _newConnectionId = "";
            _success = "Webhook added.";
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Failed: {ex.Message}"; }
    }

    async Task DeleteAsync(WebhookSubscriptionDto w)
    {
        if (!await MessageBox.ConfirmAsync("Delete Webhook", $"Delete webhook to {w.Url}?")) return;
        try { await Api.DeleteWebhookAsync(w.Id); _success = "Deleted."; await LoadAsync(); }
        catch (Exception ex) { _error = $"Failed: {ex.Message}"; }
    }

    async Task ReplayAsync(Guid deliveryId)
    {
        _error = null; _success = null;
        try
        {
            await Api.ReplayWebhookAsync(deliveryId);
            _success = "Webhook replayed.";
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Replay failed: {ex.Message}"; }
    }
}
